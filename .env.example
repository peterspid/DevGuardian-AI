# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Terminal3 Agent Auth SDK
# Use the sandbox/private key supplied by Terminal3. Keep it server-side only.
TERMINAL3_API_KEY=
TERMINAL3_PRIVATE_KEY=
TERMINAL3_DID=
TERMINAL3_ENVIRONMENT=testnet
TERMINAL3_NODE_URL=

# Persistence
MONGODB_URI=
MONGODB_DB=devguardian_ai

# Optional GitHub API token for private/high-rate repository scanning.
GITHUB_TOKEN=

# Operator access
# Required in production for protected agent, repository, deploy, and audit APIs.
DEVGUARDIAN_OPERATOR_TOKEN=
DEVGUARDIAN_REQUIRE_OPERATOR_TOKEN=true
DEVGUARDIAN_ALLOW_MEMORY_AUDIT=false

# Optional media credentials reserved for future screenshots/artifacts.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000
